@model IEnumerable<VentaMusical.Models.ViewModels.Usuarios.ListarUsuarios>

@{
    ViewBag.Title = "Listado de Usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>@ViewBag.Title</h2>
<br />

<!-- Mensajes visuales -->
@if (ViewBag.ValorMensaje == 1)
{
    <div class="alert alert-success text-center">
        @ViewBag.MensajeProceso
    </div>
}
else if (ViewBag.ValorMensaje == 0)
{
    <div class="alert alert-danger text-center">
        @ViewBag.MensajeProceso
    </div>
}

<!-- Filtros superiores -->
@using (Html.BeginForm("Index", "Usuarios", FormMethod.Get))
{
    <div class="row mb-3">
        <div class="col-md-4 align-self-end text-end">
            <input type="button" class="btn btnCreate w-100" value="Crear nuevo usuario"
                   onclick="document.location.href='@Url.Action("Create", "Usuarios")'" />
        </div>

        <div class="col-md-3">
            <label>Buscar por cédula:</label>
            @Html.TextBox("busquedaCedula", Request.QueryString["busquedaCedula"], new { @class = "form-control" })
        </div>

        <div class="col-md-2 align-self-end">
            <input type="submit" value="Buscar" class="btn btnCreate w-100" />
        </div>
    </div>
}

<!-- Tabla de usuarios -->
<table class="table table-striped table-bordered text-center custom-table">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Cédula</th>
            <th>Nombre</th>
            <th>Apellido</th>
            <th>Correo</th>
            <th>Rol</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ID</td>
                <td>@item.NumeroIdentificacion</td>
                <td>@item.Nombre</td>
                <td>@item.Apellido</td>
                <td>@item.Correo</td>
                <td>@item.Perfil</td>
                <td>
                    <a href="@Url.Action("Edit", new { id = item.ID })" class="btn btnEdit btn-sm">Editar</a>
                    <a href="@Url.Action("Details", new { id = item.ID })" class="btn btnDetails btn-sm">Detalles</a>
                    <a href="@Url.Action("Delete", new { id = item.ID })" class="btn btnDelete btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var myModalEl = document.getElementById('myModal');
            if (myModalEl) {
                var modal = new bootstrap.Modal(myModalEl);
                modal.show();
            }
        });
    </script>
}
