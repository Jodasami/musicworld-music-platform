@model VentaMusical.Models.ViewModels.Canciones.Cancion

@{
    ViewBag.Title = "Eliminar Canción";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<br />

<div class="row">
    <div class="col-md-10 offset-md-1">
        <div class="card shadow-lg p-4 rounded-4" style="background-color: #FDE2BA">

            <h4 class="text-danger text-center mb-4">¿Estás seguro que deseas eliminar esta canción?</h4>

            <div class="row">

                <!-- Columna izquierda: información de la canción -->
                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-5">@Html.DisplayNameFor(model => model.CodigoCancion)</dt>
                        <dd class="col-sm-7">@Html.DisplayFor(model => model.CodigoCancion)</dd>

                        <dt class="col-sm-5">@Html.DisplayNameFor(model => model.CodigoGenero)</dt>
                        <dd class="col-sm-7">@Html.DisplayFor(model => model.CodigoGenero)</dd>

                        <dt class="col-sm-5">@Html.DisplayNameFor(model => model.CodigoAlbum)</dt>
                        <dd class="col-sm-7">@Html.DisplayFor(model => model.CodigoAlbum)</dd>

                        <dt class="col-sm-5">@Html.DisplayNameFor(model => model.NombreCancion)</dt>
                        <dd class="col-sm-7">@Html.DisplayFor(model => model.NombreCancion)</dd>

                        <dt class="col-sm-5">@Html.DisplayNameFor(model => model.Precio)</dt>
                        <dd class="col-sm-7">₡@Html.DisplayFor(model => model.Precio)</dd>

                        <dt class="col-sm-5">@Html.DisplayNameFor(model => model.CantidadDisponible)</dt>
                        <dd class="col-sm-7">@Html.DisplayFor(model => model.CantidadDisponible)</dd>
                    </dl>
                </div>

                <!-- Columna derecha: reproducción de la canción -->
                <div class="col-md-6 text-center">
                    <h5 class="mb-3">Reproducir canción</h5>
                    <div class="ratio ratio-16x9">
                        @if (!string.IsNullOrEmpty(Model.LinkVideo))
                        {
                            <iframe src="@Model.LinkVideo"
                                    title="Muestra de la canción"
                                    frameborder="0"
                                    allowfullscreen
                                    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                                    loading="lazy">
                            </iframe>
                        }
                        else
                        {
                            <span>No hay link disponible</span>
                        }
                    </div>
                </div>

            </div>
            <br />


        </div>
        <div class="text-center mt-4">
            @using (Html.BeginForm("Delete", "Canciones", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="submit" value="Eliminar" class="btn btn-danger btn-lg me-2" />
                @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-secondary btn-lg" })
            }
        </div>
    </div>
</div>
