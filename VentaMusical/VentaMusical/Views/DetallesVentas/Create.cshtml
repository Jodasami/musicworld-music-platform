@model VentaMusical.Models.ViewModels.DetallesVentas.DetalleVentaViewModel
@{
    ViewBag.Title = "Agregar Detalle a la Venta";
}

<h2>Agregar Detalle</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />

        @Html.LabelFor(m => m.NumeroFactura, htmlAttributes: new { @class = "control-label col-md-2" })
        <div class="col-md-10">
            @Html.DropDownList("NumeroFactura", null, htmlAttributes: new { @class = "form-control" })
        </div>

        @Html.LabelFor(m => m.CodigoCancion, htmlAttributes: new { @class = "control-label col-md-2" })
        <div class="col-md-10">
            @Html.DropDownList("CodigoCancion", null, htmlAttributes: new { @class = "form-control" })
        </div>

        @Html.LabelFor(m => m.Cantidad, htmlAttributes: new { @class = "control-label col-md-2" })
        <div class="col-md-10">
            @Html.EditorFor(m => m.Cantidad, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(m => m.Cantidad, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Agregar" class="btn btn-success" />
                @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-default" })
            </div>
        </div>
    </div>
}