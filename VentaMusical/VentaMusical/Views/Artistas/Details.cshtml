@model VentaMusical.Models.ViewModels.Artistas.Artista

@{
    ViewBag.Title = "Detalles del Artista";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Detalles del Artista</h2>
<br />

<div class="row">
    <div class="col-md-10 offset-md-1">
        <div class="card shadow-sm p-4 Detalles" style="background-color:#FDE2BA;">
            <h4 class="mb-4 text-center">Información del Artista</h4>
            <div class="row">
                <!-- Columna izquierda: datos del artista -->
                <div class="col-md-7">
                    <dl class="row">
                        <dt class="col-sm-5">Código del Artista</dt>
                        <dd class="col-sm-7">@Html.DisplayFor(model => model.CodigoArtista)</dd>

                        <dt class="col-sm-5">Nombre Artístico</dt>
                        <dd class="col-sm-7">@Html.DisplayFor(model => model.NombreArtistico)</dd>

                        <dt class="col-sm-5">Nombre Real</dt>
                        <dd class="col-sm-7">@Html.DisplayFor(model => model.NombreReal)</dd>

                        <dt class="col-sm-5">Fecha de Nacimiento</dt>
                        <dd class="col-sm-7">@Html.DisplayFor(model => model.FechaNacimiento)</dd>

                        <dt class="col-sm-5">Nacionalidad</dt>
                        <dd class="col-sm-7">@Html.DisplayFor(model => model.Nacionalidad)</dd>

                        <dt class="col-sm-5">Link de Biografía</dt>
                        <dd class="col-sm-7">
                            <a href="@Model.LinkBiografia" target="_blank">@Model.LinkBiografia</a>
                        </dd>
                    </dl>
                </div>

                <!-- Columna derecha: imagen del artista -->
                <div class="col-md-5 d-flex justify-content-center align-items-center">
                    @if (!string.IsNullOrEmpty(Model.Foto))
                    {
                        <img src="@Url.Content(Model.Foto)" alt="Foto del artista" style="max-width:100%; max-height:300px; border-radius:8px;" />
                    }
                    else
                    {
                        <span>No hay imagen</span>
                    }
                </div>
            </div>
            
        </div>
    </div>
</div>

<div class="text-center mt-4">
    @Html.ActionLink("Editar", "Edit", new { id = Model.CodigoArtista }, new { @class = "btn btnEdit btn-lg" })
    <a href="@Url.Action("Index")" class="btn btn-secondary btn-lg ms-2">Volver al listado</a>
</div>
