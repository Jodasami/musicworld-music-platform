@model VentaMusical.Models.ViewModels.Generos.CrearGenero

@{
    ViewBag.Title = "Agregar Género";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="text-center">@ViewBag.Title</h2>
<br />

@if (ViewBag.ValorMensaje == 1)
{
    <div class="modal fade" id="myModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Mensaje</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                            onclick="document.location.href='@Url.Content("~/Generos/Index")'"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-success">@ViewBag.MensajeProceso</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"
                            onclick="document.location.href='@Url.Content("~/Generos/Index")'">
                        Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else if (ViewBag.ValorMensaje == 0)
{
    <div class="modal fade" id="myModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Mensaje</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger">@ViewBag.MensajeProceso</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@using (Html.BeginForm("Create", "Generos", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="card shadow-lg p-4 rounded-4" style="background-color: #FDE2BA;">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <div class="mb-3">
                    @Html.LabelFor(m => m.Descripcion, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Descripcion, new { @class = "form-control", placeholder = "Ingrese el nombre del género" })
                    @Html.ValidationMessageFor(m => m.Descripcion, "", new { @class = "text-danger" })
                </div>


            </div>
        </div>
    </div>
    <div class="d-flex justify-content-evenly mt-4">
        <input type="submit" value="Guardar Género" class="btn btnCreate btn-lg w-100" />
        <input type="button" value="Volver" class="btn btn-secondary btn-lg w-100"
               onclick="document.location.href='@Url.Content("~/Generos/Index")'" />
    </div>
}

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var myModalEl = document.getElementById('myModal');
            if (myModalEl) {
                var modal = new bootstrap.Modal(myModalEl);
                modal.show();
            }
        });
    </script>
}
