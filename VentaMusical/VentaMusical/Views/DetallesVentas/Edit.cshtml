@model VentaMusical.Models.ViewModels.DetallesVentas.DetalleVentaViewModel

@{
    ViewBag.Title = "Editar Detalle de Venta";
}

<h2>Editar Detalle</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    @Html.HiddenFor(model => model.IDDetalle)

    <div class="form-group">
        @Html.LabelFor(model => model.NumeroFactura)
        @Html.DropDownList("NumeroFactura", null, htmlAttributes: new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.CodigoCancion)
        @Html.DropDownList("CodigoCancion", null, htmlAttributes: new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.Cantidad)
        @Html.EditorFor(model => model.Cantidad, new { htmlAttributes = new { @class = "form-control" } })
    </div>

    <div class="form-group">
        <label>Subtotal</label>
        <span class="form-control">@Model.Subtotal.ToString("C")</span>
    </div>

    <button type="submit" class="btn btn-success">Guardar cambios</button>
    @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-secondary" })
}