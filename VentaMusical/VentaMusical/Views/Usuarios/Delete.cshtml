@model VentaMusical.Models.ViewModels.Usuarios.Usuario

@{
    ViewBag.Title = "Eliminar Usuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="text-center">@ViewBag.Title</h2>
<br />

<div class="d-flex justify-content-center">
    <div class="col-md-6">
        <div class="card shadow p-4 mb-4" style="background-color:#FDE2BA;">
            <h4 class="text-danger text-center mb-4">¿Estás seguro que deseas eliminar este usuario?</h4>
            <dl class="row">
                <dt class="col-sm-5">ID</dt>
                <dd class="col-sm-7">@Model.IDUsuario</dd>

                <dt class="col-sm-5">Cédula</dt>
                <dd class="col-sm-7">@Model.NumeroIdentificacion</dd>

                <dt class="col-sm-5">Nombre</dt>
                <dd class="col-sm-7">@Model.Nombre</dd>

                <dt class="col-sm-5">Apellido</dt>
                <dd class="col-sm-7">@Model.Apellido</dd>

                <dt class="col-sm-5">Género</dt>
                <dd class="col-sm-7">@Model.Genero</dd>

                <dt class="col-sm-5">Correo</dt>
                <dd class="col-sm-7">@Model.Correo</dd>
            </dl>

            <div class="text-center mt-4">
                @using (Html.BeginForm("Delete", "Usuarios", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="submit" value="Eliminar" class="btn btn-danger btn-lg me-2" />
                    <a href="@(Session["Rol"] != null && Session["Rol"].Equals("Admin") ? Url.Action("Index") : Url.Action("Dashboard","Home"))"
                       class="btn btn-secondary btn-lg">Cancelar</a>
                }
            </div>
        </div>
    </div>
</div>
