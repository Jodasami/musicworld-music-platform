@model VentaMusical.Models.Generos

@{
    ViewBag.Title = "Editar Género";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="text-center">@ViewBag.Title</h2>
<hr />

@using (Html.BeginForm("Edit", "Generos", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.CodigoGenero)

    <div class="card shadow-lg p-4 rounded-4" style="background-color: #FDE2BA">
        <div class="row justify-content-center">

            <!-- Columna única: datos del género -->
            <div class="col-md-6 d-flex flex-column align-items-center">

                <div class="w-75 mb-3">
                    @Html.LabelFor(model => model.Descripcion)
                    @Html.TextBoxFor(model => model.Descripcion, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger" })
                </div>

            </div>
        </div>
    </div>

    <br />

    <div class="d-flex justify-content-evenly">
        <input type="submit" value="Guardar cambios" class="btn btnCreate w-100 btn-lg" />
        <input type="button" class="btn btn-secondary w-100 btn-lg" value="Volver a la lista"
               onclick="document.location.href='@Url.Content("~/Generos/Index")'" />
    </div>
}
