@model List<VentaMusical.Models.ViewModels.DetallesVentas.DetalleVentaViewModel>

@{
    ViewBag.Title = "Detalles por Venta";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Detalles de Venta</h2>
<br />

<!-- Mensajes visuales -->
@if (ViewBag.ValorMensaje == 1)
{
    <div class="alert alert-success text-center">
        @ViewBag.MensajeProceso
    </div>
}
else if (ViewBag.ValorMensaje == 0)
{
    <div class="alert alert-danger text-center">
        @ViewBag.MensajeProceso
    </div>
}

<!-- Tabla de detalles -->
<table class="table table-striped table-bordered text-center custom-table">
    <thead class="table-dark">
        <tr>
            <th>Factura</th>
            <th>Código Canción</th>
            <th>Nombre Canción</th>
            <th>Cantidad</th>
            <th>Precio Unitario</th>
            <th>Subtotal</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var detalle in Model)
        {
            <tr>
                <td>@detalle.NumeroFactura</td>
                <td>@detalle.CodigoCancion</td>
                <td>@detalle.NombreCancion</td>
                <td>@detalle.Cantidad</td>
                <td>₡@detalle.PrecioUnitario.ToString("N2")</td>
                <td>₡@detalle.Subtotal.ToString("N2")</td>
                <td>
                    <a href="@Url.Action("Details", "Ventas", new { id = detalle.NumeroFactura })" class="btn btnDetails btn-sm">📄 Ver Venta</a>

                </td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <td colspan="5"><strong>Total acumulado:</strong></td>
            <td colspan="2">₡@Model.Sum(d => d.Subtotal).ToString("N2")</td>
        </tr>
    </tfoot>
</table>
