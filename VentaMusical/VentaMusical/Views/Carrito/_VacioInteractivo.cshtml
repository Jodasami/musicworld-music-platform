@model VentaMusical.Models.ViewModels.Carritos.VaciarCarrito

<div class="text-center p-4 border rounded-3 bg-light">
    <h3 class="mb-3">@Model.Icono @Model.Titulo</h3>
    <p class="text-muted">@Model.Mensaje</p>

    <div class="mt-3">
        @foreach (var boton in Model.Botones)
        {
            @Html.ActionLink(boton.Texto, boton.Accion, boton.Controlador,
                     boton.RutaParametros,
                     new { @class = boton.ClaseCss, title = boton.Titulo })
        }
    </div>
</div>